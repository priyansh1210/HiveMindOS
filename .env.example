# ============================================================
# Copy this file to .env (root) and backend/.env, then fill in values.
# ============================================================

# --- LLM providers ---
# Free: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional second Gemini key (use a different Google account) for free-tier failover
GEMINI_API_KEY_2=
# Free: https://console.groq.com
GROQ_API_KEY=
# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
# --- Model overrides (optional) ---
GEMINI_ORCHESTRATOR_MODEL=gemini-2.5-pro
GEMINI_AGENT_MODEL=gemini-2.5-flash
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# --- Server ---
ENVIRONMENT=development
# Comma-separated allowed origins for CORS. In production set this to the
# deployed frontend URL, e.g. "https://your-app.vercel.app".
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend (use in frontend/.env.local) ---
# Single env var; the frontend derives the WebSocket URL by replacing http→ws.
# NEXT_PUBLIC_API_BASE=http://localhost:8000
